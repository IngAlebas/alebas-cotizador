# Copia a .env.local y rellena.
# Base del webhook de n8n desplegado en Railway (sin slash final).
# Ejemplo: https://n8n-production-xxxx.up.railway.app/webhook
REACT_APP_N8N_BASE_URL=

# (Opcional) token compartido; n8n debe validarlo en cada workflow.
REACT_APP_N8N_TOKEN=

# ─── Variables de entorno que se configuran en n8n (NO en el frontend) ───
# Google Maps + Solar APIs (una sola clave con ambas APIs habilitadas)
# GOOGLE_API_KEY=
#
# IA cascade — gratuitas (configurar las que tengas; el cascade usa la primera disponible)
# Groq  → https://console.groq.com  (Llama 3.3 70B, 14,400 req/day gratis)
# GROQ_API_KEY=
# Gemini Flash → https://aistudio.google.com/app/apikey  (1,500 req/day gratis)
# GOOGLE_AI_KEY=
# Mistral → https://console.mistral.ai  (free tier)
# MISTRAL_API_KEY=
#
# IA de pago — Claude (último recurso; también usado como fallback en solar-roof)
# ANTHROPIC_API_KEY=
#
# Otras APIs externas usadas en workflows n8n
# NREL_API_KEY=   (PVWatts; DEMO_KEY funciona con límite de 1,000 req/día)
