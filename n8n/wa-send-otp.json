          "conditions": [
            { "id": "ok-rate", "leftValue": "={{ $json.ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "true", "singleValue": true } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "wa-snd-006",
      "name": "Rate ok?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1340, 150]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO otp_codes (phone, code_hash, expires_at, ip) VALUES ($1,$2,$3,$4::inet) RETURNING id",
        "options": {
          "queryReplacement": "={{ [$json.phone, $json.codeHash, $json.expiresAt, $json.ip || ''] }}"
        }
      },
      "id": "wa-snd-007",
      "name": "Insert OTP",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1560, 0],
      "credentials": { "postgres": { "id": "ALEBAS_POSTGRES", "name": "ALEBAS Postgres" } }
    },
    {
      "parameters": {
        "jsCode": "const rl = $('Check rate limit').first().json;\nconst phone = rl.phone;\nconst code = rl.code;\nconst phoneNumberId = process.env.WHATSAPP_PHONE_NUMBER_ID;\nconst token = process.env.WHATSAPP_ACCESS_TOKEN;\nconst url = 'https://graph.facebook.com/v18.0/' + phoneNumberId + '/messages';\nconst body = JSON.stringify({\n  messaging_product: 'whatsapp',\n  recipient_type: 'individual',\n  to: phone,\n  type: 'template',\n  template: {\n    name: 'solar_otp',\n    language: { code: 'es' },\n    components: [{ type: 'body', parameters: [{ type: 'text', text: code }] }]\n  }\n});\nreturn [{ json: { phone, code, url, token, body } }];"
      },
