      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "alebas-wa-send-otp"
    },
    {
      "parameters": {
        "jsCode": "const src = $input.first().json;\nconst body = src.body || src;\nconst rawPhone = (body.phone || '').toString().trim();\nconst ip = (body.ip || src.headers?.['x-forwarded-for'] || src.headers?.['x-real-ip'] || '').toString().trim();\n\nconst digits = rawPhone.replace(/\\D/g, '');\nlet phone = '';\nif (digits.length === 10) {\n  phone = '+57' + digits;\n} else if (digits.startsWith('57') && digits.length === 12) {\n  phone = '+' + digits;\n} else if (digits.startsWith('57') && digits.length > 12) {\n  phone = '+' + digits.slice(0, 12);\n} else {\n  return [{ json: { ok: false, reason: 'invalid_phone' } }];\n}\n\nif (!phone.startsWith('+57') || phone.length !== 13) {\n  return [{ json: { ok: false, reason: 'invalid_phone' } }];\n}\n\nreturn [{ json: { ok: true, phone, ip } }];"
      },
      "id": "wa-snd-002",
      "name": "Normalize phone",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            { "id": "ok-phone", "leftValue": "={{ $json.ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "true", "singleValue": true } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "wa-snd-003",
      "name": "Phone valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COUNT(*) as cnt FROM otp_codes WHERE phone=$1 AND created_at > NOW() - INTERVAL '1 hour' AND consumed_at IS NULL",
        "options": {
          "queryReplacement": "={{ $json.phone }}"
        }
      },
      "id": "wa-snd-004",
      "name": "Rate limit check",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [900, 150],
      "credentials": { "postgres": { "id": "ALEBAS_POSTGRES", "name": "ALEBAS Postgres" } }
    },
    {
      "parameters": {
        "jsCode": "const db = $input.first().json;\nconst norm = $('Normalize phone').first().json;\nconst phone = norm.phone;\nconst ip = norm.ip || '';\nconst cnt = Number(db.cnt || 0);\n\nif (cnt >= 3) {\n  return [{ json: { ok: false, reason: 'rate_limit', message: 'Demasiados intentos. Espera 1 hora.' } }];\n}\n\nconst code = Math.floor(100000 + Math.random() * 900000).toString();\nconst crypto = require('crypto');\nconst salt = process.env.OTP_SALT || 'solarhub2026';\nconst hash = crypto.createHmac('sha256', salt).update(code).digest('hex');\nconst expiresAt = new Date(Date.now() + 5 * 60000).toISOString();\n\nreturn [{ json: { ok: true, phone, ip, code, codeHash: hash, expiresAt } }];"
      },
      "id": "wa-snd-005",
      "name": "Check rate limit",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 150]
    },
