{
  "name": "ALEBAS — solar-geotiff-proxy",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "solar-geotiff",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "g4000000-0001-4000-9000-000000000001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "alebas-solar-geotiff"
    },
    {
      "parameters": {
        "jsCode": "// Valida que la URL sea de Google Solar (security).\n// Acepta solo https://solar.googleapis.com/* — evita usar este endpoint\n// como proxy abierto a cualquier URL.\nconst src = $input.first().json;\nconst body = src.body || src;\nconst url = body.url;\nif (!url || typeof url !== 'string') {\n  return [{ json: { ok: false, reason: 'invalid_input', detail: 'url requerida' } }];\n}\nif (!url.startsWith('https://solar.googleapis.com/')) {\n  return [{ json: { ok: false, reason: 'invalid_url', detail: 'url debe ser de solar.googleapis.com' } }];\n}\nreturn [{ json: { url } }];"
      },
      "id": "g4000000-0001-4000-9000-000000000002",
      "name": "Validate URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-is-error",
              "leftValue": "={{ $json.ok }}",
              "rightValue": false,
              "operator": { "type": "boolean", "operation": "equal" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "g4000000-0001-4000-9000-000000000003",
      "name": "If error",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "url": "={{ $json.url }}",
        "options": {
          "timeout": 30000,
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      },
      "id": "g4000000-0001-4000-9000-000000000004",
      "name": "Fetch GeoTIFF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 420]
    },
    {
      "parameters": {
        "jsCode": "// Convierte el binario descargado a base64 para devolverlo en JSON.\n// n8n ya almacena los binarios como base64 en item.binary.data.data,\n// así que solo extraemos ese campo.\nconst item = $input.first();\nconst bin = item.binary?.data;\nif (!bin || !bin.data) {\n  return [{ json: { ok: false, reason: 'no_binary', detail: 'el endpoint no devolvió contenido' } }];\n}\nreturn [{ json: {\n  ok: true,\n  base64: bin.data,\n  mimeType: bin.mimeType || 'image/tiff',\n  size: Number(bin.fileSize) || null,\n} }];"
      },
      "id": "g4000000-0001-4000-9000-000000000005",
      "name": "To base64",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 420]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}",
        "options": {}
      },
      "id": "g4000000-0001-4000-9000-000000000006",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1340, 420]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}",
        "options": { "responseCode": 400 }
      },
      "id": "g4000000-0001-4000-9000-000000000007",
      "name": "Respond error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [900, 180]
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Validate URL", "type": "main", "index": 0 }]] },
    "Validate URL": { "main": [[{ "node": "If error", "type": "main", "index": 0 }]] },
    "If error": {
