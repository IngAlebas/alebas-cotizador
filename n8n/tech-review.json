    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT q.id, q.status, q.doc_status, q.payload, q.tech_notes, q.tech_approved_at, q.tech_token, t.name as tech_name, t.phone as tech_phone FROM quotes q LEFT JOIN technicians t ON t.id=q.technician_id WHERE q.tech_token=$1::uuid",
