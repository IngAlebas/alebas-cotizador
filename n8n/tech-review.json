    {
      "parameters": {
        "jsCode": "const row = $input.first().json || {};\nif (!row.id) throw new Error('Token inválido o cotización no encontrada');\n\n// Parse payload JSONB if it's a string\nlet payload = row.payload;\nif (typeof payload === 'string') {\n  try { payload = JSON.parse(payload); } catch { payload = {}; }\n}\n\nreturn [{ json: { ok: true, quote: {\n  id: row.id,\n  status: row.status,\n  doc_status: row.doc_status,\n  payload: payload,\n  tech_notes: row.tech_notes,\n  tech_approved_at: row.tech_approved_at,\n  tech_token: row.tech_token,\n  tech_name: row.tech_name,\n  tech_phone: row.tech_phone,\n} } }];"
