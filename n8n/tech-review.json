        "query": "UPDATE quotes SET doc_status=CASE WHEN $1='approve' THEN 'aprobado' ELSE 'cambios_solicitados' END, tech_approved_at=CASE WHEN $1='approve' THEN NOW() ELSE NULL END, tech_notes=$2, status=CASE WHEN $1='approve' THEN 'documentos_aprobados' ELSE 'en_revision' END WHERE tech_token=$3::uuid RETURNING id, status, doc_status",
        "options": {
          "queryReplacement": "={{ [$json.action, $json.notes, $json.token] }}"
        }
      },
