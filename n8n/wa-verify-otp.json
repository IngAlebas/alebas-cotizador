          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            { "id": "ok-code", "leftValue": "={{ $json.ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "true", "singleValue": true } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "wa-ver-006",
      "name": "Code valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1340, 150]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE otp_codes SET consumed_at=NOW() WHERE id=$1",
        "options": {
          "queryReplacement": "={{ $json.otpId }}"
        }
      },
      "id": "wa-ver-007",
      "name": "Mark consumed",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1560, 0],
      "credentials": { "postgres": { "id": "ALEBAS_POSTGRES", "name": "ALEBAS Postgres" } }
    },
    {
      "parameters": {
        "jsCode": "const verified = $('Verify code').first().json;\nconst phone = verified.phone;\nconst crypto = require('crypto');\nconst secret = process.env.JWT_SECRET || 'solarhub2026secret';\nconst payload = JSON.stringify({ phone, iat: Date.now(), exp: Date.now() + 30 * 60000 });\nconst token = crypto.createHmac('sha256', secret).update(payload).digest('hex');\nreturn [{ json: { ok: true, token, payload, phone, message: 'Teléfono verificado correctamente' } }];"
      },
      "id": "wa-ver-008",
      "name": "Generate token",
